<%- include('../partials/head', { title: 'Sign In | Aurae' }) %>

<main class="auth-page">
  <div class="form-card">
    <a href="/" class="logo-text" style="font-family: var(--font-heading); font-size: 2rem; text-decoration: none;">Aurae</a>
    <p class="text-center mb-lg" style="font-size: var(--text-sm); color: var(--color-espresso-light);">Welcome back to your kitchen</p>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <ul class="form-errors">
        <% errors.forEach(function(err) { %>
          <li><%= err %></li>
        <% }) %>
      </ul>
    <% } %>

    <form action="/auth/login<%= typeof redirect !== 'undefined' && redirect ? '?redirect=' + encodeURIComponent(redirect) : '' %>" method="POST">
      <div class="form-group">
        <input type="text" name="username" id="username" placeholder=" " value="<%= typeof old !== 'undefined' ? old.username || '' : '' %>" required>
        <label for="username">Username</label>
      </div>

      <div class="form-group">
        <input type="password" name="password" id="password" placeholder=" " required>
        <label for="password">Password</label>
      </div>

      <button type="submit" class="btn btn--primary btn--full btn--lg">Sign In</button>
    </form>

    <p class="auth-link">
      Don't have an account? <a href="/auth/register">Create one</a>
    </p>
  </div>
</main>

<%- include('../partials/footer') %>
