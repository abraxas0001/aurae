<%- include('../partials/head', { title: recipe.title + ' | Aurae' }) %>
<%- include('../partials/header') %>

<!-- Reading Progress Bar -->
<div class="reading-progress" id="readingProgress"></div>

<main>
  <!-- Full-bleed Hero Image -->
  <div class="recipe-hero">
    <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>">
    <div class="recipe-hero__overlay"></div>
    <div class="recipe-hero__content">
      <span class="recipe-hero__category"><%= recipe.category_name %></span>
      <h1 class="recipe-hero__title"><%= recipe.title %></h1>
    </div>
  </div>

  <!-- Meta Bar (overlapping hero) -->
  <div class="recipe-meta-bar">
    <div class="recipe-meta-item">
      <div class="recipe-meta-item__icon">
        <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <div class="recipe-meta-item__value"><%= recipe.prep_time %> min</div>
      <div class="recipe-meta-item__label">Prep Time</div>
    </div>
    <div class="recipe-meta-item">
      <div class="recipe-meta-item__icon">
        <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
      </div>
      <div class="recipe-meta-item__value"><%= recipe.cook_time %> min</div>
      <div class="recipe-meta-item__label">Cook Time</div>
    </div>
    <div class="recipe-meta-item">
      <div class="recipe-meta-item__icon">
        <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="recipe-meta-item__value"><%= recipe.servings %></div>
      <div class="recipe-meta-item__label">Servings</div>
    </div>
    <div class="recipe-meta-item">
      <div class="recipe-meta-item__icon">
        <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <div class="recipe-meta-item__value"><%= recipe.difficulty %></div>
      <div class="recipe-meta-item__label">Difficulty</div>
    </div>
  </div>

  <!-- Culinary Ornament Band -->
  <div class="recipe-culinary-decor" aria-hidden="true">
    <svg viewBox="0 0 1000 130" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">

      <!-- ── LEFT: ROSEMARY SPRIG ── -->
      <g opacity="0.38" stroke="#8B9D77" stroke-width="1" stroke-linecap="round">
        <path d="M 18 122 Q 44 82 58 18"/>
        <!-- left-side needles -->
        <line x1="25" y1="106" x2="15" y2="97"/>
        <line x1="32" y1="91"  x2="21" y2="84"/>
        <line x1="38" y1="76"  x2="27" y2="70"/>
        <line x1="43" y1="61"  x2="32" y2="56"/>
        <line x1="48" y1="46"  x2="37" y2="43"/>
        <line x1="51" y1="32"  x2="41" y2="30"/>
        <!-- right-side needles -->
        <line x1="27" y1="100" x2="37" y2="93"/>
        <line x1="34" y1="85"  x2="44" y2="79"/>
        <line x1="40" y1="70"  x2="50" y2="65"/>
        <line x1="45" y1="55"  x2="55" y2="52"/>
        <line x1="49" y1="41"  x2="59" y2="39"/>
        <line x1="53" y1="26"  x2="62" y2="26"/>
      </g>

      <!-- ── LEFT: FORK ── -->
      <g opacity="0.4" stroke="#C67D5B" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" transform="translate(108, 12)">
        <!-- tines -->
        <line x1="6"  y1="5"  x2="6"  y2="36"/>
        <line x1="11" y1="3"  x2="11" y2="36"/>
        <line x1="17" y1="3"  x2="17" y2="36"/>
        <line x1="22" y1="5"  x2="22" y2="36"/>
        <!-- rounded tine tips -->
        <path d="M5,5 Q4,1 6,0 Q8,1 7,5"/>
        <path d="M10,3 Q10,-1 13,-2 Q16,-1 16,3" stroke-width="1"/>
        <path d="M16,3 Q17,-1 19,-2 Q22,-1 21,3" stroke-width="1"/>
        <path d="M21,5 Q20,1 22,0 Q24,1 23,5"/>
        <!-- neck ferrule -->
        <path d="M6,36 Q5,44 14,46 Q23,44 22,36"/>
        <!-- handle -->
        <line x1="14" y1="46" x2="14" y2="98"/>
        <!-- pommel -->
        <ellipse cx="14" cy="101" rx="4" ry="2.5"/>
      </g>

      <!-- ── LEFT: small scattered peppercorns ── -->
      <circle cx="168" cy="112" r="2.2" fill="#C67D5B" opacity="0.22"/>
      <circle cx="178" cy="106" r="1.5" fill="#C67D5B" opacity="0.16"/>
      <circle cx="186" cy="115" r="1.8" fill="#8B9D77"  opacity="0.18"/>

      <!-- ── LEFT-CENTER: small leaf cluster ── -->
      <g opacity="0.22" stroke="#8B9D77" stroke-width="1" stroke-linecap="round">
        <path d="M210,72 Q220,56 236,63 Q224,75 210,72"/>
        <path d="M210,72 Q201,57 215,48 Q221,60 210,72"/>
        <path d="M210,72 Q220,83 231,77 Q222,66 210,72"/>
      </g>

      <!-- ── CENTER LINE (left half) ── -->
      <line x1="256" y1="65" x2="386" y2="65" stroke="#C67D5B" stroke-width="0.8" stroke-dasharray="4,5" opacity="0.22"/>

      <!-- small ornament left of center -->
      <g opacity="0.32" transform="translate(394, 57)">
        <circle cx="8" cy="8" r="4" stroke="#C67D5B" stroke-width="1" fill="none"/>
        <circle cx="8" cy="8" r="1.2" fill="#C67D5B" opacity="0.55"/>
        <line x1="8" y1="2.5" x2="8" y2="0"  stroke="#C67D5B" stroke-width="1"/>
        <line x1="8" y1="13.5" x2="8" y2="16" stroke="#C67D5B" stroke-width="1"/>
        <line x1="2.5" y1="8" x2="0" y2="8"   stroke="#C67D5B" stroke-width="1"/>
        <line x1="13.5" y1="8" x2="16" y2="8"  stroke="#C67D5B" stroke-width="1"/>
      </g>

      <line x1="412" y1="65" x2="462" y2="65" stroke="#C67D5B" stroke-width="0.8" stroke-dasharray="4,5" opacity="0.22"/>

      <!-- ── CENTER: Plate / Crest motif ── -->
      <g opacity="0.38" transform="translate(471, 40)">
        <!-- plate outer rim -->
        <circle cx="29" cy="29" r="25" stroke="#C9A84C" stroke-width="1.3" fill="none"/>
        <!-- plate inner well -->
        <circle cx="29" cy="29" r="17" stroke="#C9A84C" stroke-width="0.8" fill="none"/>
        <!-- inner detail ring -->
        <circle cx="29" cy="29" r="9"  stroke="#C9A84C" stroke-width="0.6" fill="none" opacity="0.6"/>
        <!-- cardinal dots on rim -->
        <circle cx="29"   cy="4"    r="1.8" fill="#C9A84C"/>
        <circle cx="29"   cy="54"   r="1.8" fill="#C9A84C"/>
        <circle cx="4"    cy="29"   r="1.8" fill="#C9A84C"/>
        <circle cx="54"   cy="29"   r="1.8" fill="#C9A84C"/>
        <!-- diagonal small dots -->
        <circle cx="10.5" cy="10.5" r="1.2" fill="#C9A84C" opacity="0.6"/>
        <circle cx="47.5" cy="10.5" r="1.2" fill="#C9A84C" opacity="0.6"/>
        <circle cx="10.5" cy="47.5" r="1.2" fill="#C9A84C" opacity="0.6"/>
        <circle cx="47.5" cy="47.5" r="1.2" fill="#C9A84C" opacity="0.6"/>
        <!-- etched cross -->
        <line x1="29" y1="12" x2="29" y2="46" stroke="#C9A84C" stroke-width="0.6" opacity="0.4"/>
        <line x1="12" y1="29" x2="46" y2="29" stroke="#C9A84C" stroke-width="0.6" opacity="0.4"/>
      </g>

      <line x1="534" y1="65" x2="584" y2="65" stroke="#C67D5B" stroke-width="0.8" stroke-dasharray="4,5" opacity="0.22"/>

      <!-- small ornament right of center -->
      <g opacity="0.32" transform="translate(592, 57)">
        <circle cx="8" cy="8" r="4" stroke="#C67D5B" stroke-width="1" fill="none"/>
        <circle cx="8" cy="8" r="1.2" fill="#C67D5B" opacity="0.55"/>
        <line x1="8" y1="2.5" x2="8" y2="0"  stroke="#C67D5B" stroke-width="1"/>
        <line x1="8" y1="13.5" x2="8" y2="16" stroke="#C67D5B" stroke-width="1"/>
        <line x1="2.5" y1="8" x2="0" y2="8"   stroke="#C67D5B" stroke-width="1"/>
        <line x1="13.5" y1="8" x2="16" y2="8"  stroke="#C67D5B" stroke-width="1"/>
      </g>

      <!-- ── CENTER LINE (right half) ── -->
      <line x1="610" y1="65" x2="740" y2="65" stroke="#C67D5B" stroke-width="0.8" stroke-dasharray="4,5" opacity="0.22"/>

      <!-- ── RIGHT-CENTER: small leaf cluster ── -->
      <g opacity="0.22" stroke="#8B9D77" stroke-width="1" stroke-linecap="round">
        <path d="M790,72 Q780,56 764,63 Q776,75 790,72"/>
        <path d="M790,72 Q799,57 785,48 Q779,60 790,72"/>
        <path d="M790,72 Q780,83 769,77 Q778,66 790,72"/>
      </g>

      <!-- ── RIGHT: small scattered peppercorns ── -->
      <circle cx="822" cy="112" r="2.2" fill="#8B9D77"  opacity="0.18"/>
      <circle cx="832" cy="106" r="1.5" fill="#C67D5B" opacity="0.16"/>
      <circle cx="840" cy="116" r="1.8" fill="#C67D5B" opacity="0.22"/>

      <!-- ── RIGHT: SPOON ── -->
      <g opacity="0.4" stroke="#8B9D77" stroke-width="1.3" stroke-linecap="round" transform="translate(848, 10)">
        <!-- spoon bowl -->
        <ellipse cx="15" cy="20" rx="12" ry="17" stroke-width="1.3" fill="none"/>
        <!-- bowl highlight -->
        <path d="M10,13 Q11,8 15,7" stroke-width="0.9" opacity="0.55"/>
        <!-- stem -->
        <line x1="15" y1="37" x2="15" y2="100"/>
        <!-- pommel -->
        <ellipse cx="15" cy="104" rx="4.5" ry="2.5"/>
      </g>

      <!-- ── RIGHT: WHISK ── -->
      <g opacity="0.36" stroke="#C67D5B" stroke-width="1.1" stroke-linecap="round" transform="translate(906, 8)">
        <!-- handle -->
        <line x1="14" y1="58" x2="14" y2="112"/>
        <!-- handle ribbing (two bands) -->
        <line x1="10" y1="75" x2="18" y2="75" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="10" y1="84" x2="18" y2="84" stroke-width="1.8" stroke-linecap="round"/>
        <!-- whisk wires (looping upward from handle top) -->
        <path d="M14,58 Q3,44 6,26 Q10,14 14,12"/>
        <path d="M14,58 Q7,42 9,24 Q12,13 14,12"/>
        <path d="M14,58 Q21,42 19,24 Q16,13 14,12"/>
        <path d="M14,58 Q25,44 22,26 Q18,14 14,12"/>
        <!-- wire loop at top -->
        <ellipse cx="14" cy="11" rx="5" ry="3.5" stroke-width="1"/>
      </g>

      <!-- ── RIGHT: THYME SPRIG ── -->
      <g opacity="0.38" stroke="#8B9D77" stroke-width="1" stroke-linecap="round">
        <path d="M 982 122 Q 958 82 944 18"/>
        <!-- small round leaves left of stem -->
        <circle cx="976" cy="106" r="4.5" fill="none" stroke-width="0.9"/>
        <circle cx="969" cy="90"  r="4"   fill="none" stroke-width="0.9"/>
        <circle cx="963" cy="74"  r="3.8" fill="none" stroke-width="0.9"/>
        <circle cx="957" cy="58"  r="3.5" fill="none" stroke-width="0.9"/>
        <circle cx="952" cy="43"  r="3"   fill="none" stroke-width="0.9"/>
        <circle cx="947" cy="29"  r="2.5" fill="none" stroke-width="0.9"/>
        <!-- small round leaves right of stem -->
        <circle cx="965" cy="99"  r="4"   fill="none" stroke-width="0.9"/>
        <circle cx="959" cy="83"  r="3.8" fill="none" stroke-width="0.9"/>
        <circle cx="953" cy="67"  r="3.5" fill="none" stroke-width="0.9"/>
        <circle cx="948" cy="52"  r="3"   fill="none" stroke-width="0.9"/>
        <circle cx="944" cy="37"  r="2.5" fill="none" stroke-width="0.9"/>
      </g>

    </svg>
  </div>

  <!-- Description -->
  <p class="recipe-description"><% if (recipe.description && recipe.description.length > 1) { %><span class="drop-cap"><%= recipe.description.charAt(0) %></span><span class="drop-cap-body"><%= recipe.description.slice(1) %></span><% } else { %><%= recipe.description %><% } %></p>

  <!-- Favorite Button -->
  <div class="text-center mb-xl">
    <% if (user) { %>
      <button class="favorite-btn <%= isFavorited ? 'is-favorited' : '' %>" data-recipe-id="<%= recipe.id %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span><%= isFavorited ? 'Saved' : 'Save Recipe' %></span>
      </button>
    <% } else { %>
      <a href="/auth/login?redirect=<%= encodeURIComponent('/recipes/' + recipe.slug) %>" class="favorite-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span>Sign in to Save</span>
      </a>
    <% } %>
  </div>

  <!-- Decorative Divider -->
  <div class="section-divider">
    <img src="/svg/botanical-2.svg" alt="" aria-hidden="true">
  </div>

  <!-- Two-column: Ingredients + Instructions -->
  <div class="recipe-content">
    <div class="recipe-content__sidebar">
      <div class="ingredients-list">
        <h3>Ingredients</h3>
        <ul>
          <% const ingredients = JSON.parse(recipe.ingredients); %>
          <% ingredients.forEach(function(item) { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      </div>
    </div>

    <div>
      <div class="instructions-list">
        <h3>Instructions</h3>
        <% const instructions = JSON.parse(recipe.instructions); %>
        <% instructions.forEach(function(step) { %>
          <div class="instruction-step">
            <span class="instruction-step__number"><%= String(step.step).padStart(2, '0') %></span>
            <p class="instruction-step__text"><%= step.text %></p>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Author -->
  <div class="recipe-author">
    <% 
      const authorName = recipe.author_name || 'The Aurae Kitchen';
      const isAuraeKitchen = authorName === 'Aurae Kitchen' || authorName === 'The Aurae Kitchen';
      const displayName = isAuraeKitchen ? authorName : `Chef ${authorName}`;
    %>
    <span>Recipe by <strong><%= displayName %></strong></span>
    <br>
    <span style="font-size: var(--text-xs); color: var(--color-sage);">
      <%= new Date(recipe.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
    </span>
  </div>

  <!-- Related Recipes -->
  <% if (related && related.length > 0) { %>
    <section class="related-recipes">
      <div class="container">
        <div class="section-heading" data-animate>
          <span class="section-label">More to Explore</span>
          <h2>You Might Also Like</h2>
        </div>
        <div class="recipe-grid" data-animate-stagger>
          <% related.forEach(function(recipe) { %>
            <%- include('../partials/recipe-card', { recipe }) %>
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>
</main>

<%- include('../partials/footer') %>
