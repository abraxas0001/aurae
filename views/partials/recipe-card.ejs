<a href="/recipes/<%= recipe.slug %>" class="recipe-card">
  <div class="recipe-card__image-wrapper">
    <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>" loading="lazy">
    <div class="recipe-card__overlay">
      <span class="recipe-card__category"><%= recipe.category_name || recipe.categoryName || '' %></span>
    </div>
  </div>
  <div class="recipe-card__content">
    <h3 class="recipe-card__title"><%= recipe.title %></h3>
    <p class="recipe-card__description"><%= recipe.description %></p>
    <div class="recipe-card__meta">
      <span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <%= (recipe.prep_time || 0) + (recipe.cook_time || 0) %> min
      </span>
      <span><%= recipe.difficulty %></span>
      <span><%= recipe.servings %> servings</span>
    </div>
  </div>
</a>
